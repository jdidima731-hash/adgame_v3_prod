# ══════════════════════════════════════════════════════════════
# AdGame Pro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════

# ─── Base de données PostgreSQL ───────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://adgame:adgame@localhost:5432/adgame"

# ─── Serveur ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Sécurité ────────────────────────────────────────────────
# Générer avec: openssl rand -hex 64
SESSION_SECRET=change-me-in-production-use-long-random-string-64chars

# ─── Flouci (Paiement en ligne Tunisie) ───────────────────────
# Obtenir vos clés sur https://developer.flouci.com
# 1. Créez un compte développeur Flouci
# 2. Créez une application de type "Payment"
# 3. Copiez app_token et app_secret ci-dessous
FLOUCI_APP_TOKEN=your_flouci_app_token_here
FLOUCI_APP_SECRET=your_flouci_app_secret_here
#
# En production, configurer votre webhook Flouci vers :
#   POST https://votre-domaine.com/api/payments/flouci/webhook

# ─── Emails ───────────────────────────────────────────────────
# Au moins UNE des options suivantes doit être configurée en production.
# En dev: les emails sont simplement affichés dans les logs.

# Option 1 — Resend (recommandé, gratuit jusqu'à 3000 emails/mois)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=AdGame Pro <noreply@adgame.tn>

# Option 2 — SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@adgame.tn

# Option 3 — Nodemailer SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@gmail.com
# SMTP_PASS=votre_app_password
# EMAIL_FROM=noreply@adgame.tn

# ─── Upload vidéo (production) ────────────────────────────────
# Option 1 — Cloudinary
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_UPLOAD_PRESET=adgame_unsigned

# Option 2 — AWS S3
# AWS_BUCKET=adgame-videos
# AWS_REGION=eu-west-3
# AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx

